# ─────────────────────────────────────────────────
# APEX Backend — Environment Variables
# Copy to .env: cp .env.example .env
# ─────────────────────────────────────────────────

# Server port (frontend Vite proxy expects 3001)
PORT=3001

# Request timeout in milliseconds
FETCH_TIMEOUT=8000

# SQLite database path (auto-created)
DB_PATH=./data/apex_memory.db

# ── Optional API keys (all gracefully fallback without these) ──

# FRED (Federal Reserve Economic Data) — free at fred.stlouisfed.org
# Improves macro layer: precise CPI, GDP, yield curve data
FRED_API_KEY=

# Alpha Vantage — free at alphavantage.co (limited usage without key)
ALPHA_VANTAGE_KEY=demo

# ── Discovery Scanner Universe ──────────────────────────────────
# Comma-separated list of tickers to scan in the Discovery Engine
SCAN_UNIVERSE=NVDA,AAPL,MSFT,GOOGL,AMZN,META,TSLA,JPM,XOM,CVX,AMD,INTC,NFLX,CRM,BA,GS,WMT,JNJ,PFE,V,MA,PYPL,COIN,PLTR,SPY,QQQ
